# Shared runtime settings
TZ=UTC

# Postgres
POSTGRES_DB=audience_engine
POSTGRES_USER=audience_engine
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# ClickHouse
CLICKHOUSE_DB=audience_engine
CLICKHOUSE_USER=audience_engine
CLICKHOUSE_PASSWORD=change_me
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_please
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Ollama
OLLAMA_PORT=11434

# Airflow
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=replace_with_32_urlsafe_base64_key
AIRFLOW_WEBSERVER_SECRET_KEY=replace_with_long_random_string
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_EMAIL=admin@example.com
